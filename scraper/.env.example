# URL of the whatsapp-nagger ingest endpoint.
# For local dev: http://localhost:8080/ingest/transactions
# For prod: https://nagger.fly.dev/ingest/transactions
INGEST_URL=http://localhost:8080/ingest/transactions

# Shared HMAC secret. MUST match INGEST_SECRET in the Go bot's env.
INGEST_SECRET=

# How many days of history to fetch on first run. Subsequent runs start from
# the last successful run's fetchedAt, minus a small overlap window.
BACKFILL_DAYS=35

# Credentials: the scraper reads these from the macOS Keychain by default.
# If you're running on a non-Mac dev machine or in CI, set them here and they
# will take precedence over the Keychain.
# CAL_USERNAME=
# CAL_PASSWORD=

# If your Cal login exposes more than one card/account, set this to the last 4
# digits of the card you want to track (comma-separated for multiple). Leave
# empty to include all accounts. Do a dry-run first — the scraper logs each
# account's last4 so you know what to pick.
# CAL_CARD_LAST4=1234
