# Required
ANTHROPIC_API_KEY=your-api-key-here

# Messenger mode: "terminal" (default) or "whatsapp"
MESSENGER=terminal

# WhatsApp settings (only needed when MESSENGER=whatsapp)
WHATSAPP_PHONE=972501234567
WHATSAPP_GROUP_JID=
WHATSAPP_DB_PATH=whatsapp_session.db

# Task database path
TASKS_DB_PATH=tasks.db

# Daily digest time (24h format in configured timezone). Leave empty to disable.
DIGEST_HOUR=

# Personas: the bot loads family members from personas.md by default.
# Copy personas.md.example to personas.md and customize it.
# Alternatively, set FAMILY_MEMBERS as a single string or point PERSONAS_FILE to a custom path.
PERSONAS_FILE=personas.md
FAMILY_MEMBERS=

# Timezone for date handling and daily digest
TIMEZONE=Asia/Jerusalem

# Secret token to protect the /pair web endpoint. Leave empty to disable.
QR_TOKEN=
