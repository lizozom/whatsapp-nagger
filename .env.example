# Required
ANTHROPIC_API_KEY=your-api-key-here

# Messenger mode: "terminal" (default) or "whatsapp"
MESSENGER=terminal

# WhatsApp settings (only needed when MESSENGER=whatsapp)
WHATSAPP_PHONE=972501234567
WHATSAPP_GROUP_JID=
WHATSAPP_DB_PATH=whatsapp_session.db

# Task database path
TASKS_DB_PATH=tasks.db

# Daily digest time (24h format in configured timezone). Leave empty to disable.
DIGEST_HOUR=

# Personas: the bot loads family members from personas.md by default.
# Copy personas.md.example to personas.md and customize it.
# Alternatively, set FAMILY_MEMBERS as a single string or point PERSONAS_FILE to a custom path.
PERSONAS_FILE=personas.md
FAMILY_MEMBERS=

# Timezone for date handling and daily digest
TIMEZONE=Asia/Jerusalem

# Secret token to protect the /pair web endpoint. Leave empty to disable.
QR_TOKEN=

# Ingest HTTP endpoint for external scrapers (Cal / Max / ...).
# Set INGEST_SECRET to a long random string to enable POST /ingest/transactions.
# Leave empty to disable the ingest server entirely.
INGEST_SECRET=
INGEST_PORT=8080

# Billing cycle day — the day of the month that Cal/Max cuts your statement.
# Used by the expense tools to compute the "current cycle" date range.
# A cycle runs from BILLING_DAY of one month through the day before BILLING_DAY
# of the next, inclusive. Default: 10.
BILLING_DAY=10

# Card ownership: maps family members to the cards they own so the bot can
# answer "how much did I spend vs Denis". Format:
#   Owner1:provider/last4,provider/last4;Owner2:provider/last4
# Example:
#   CARD_OWNERS=Liza:max/1518,max/4718,cal/4973;Denis:max/4327
CARD_OWNERS=
